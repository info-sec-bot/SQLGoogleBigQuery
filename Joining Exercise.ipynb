   "source": [
    "#### Construct query and validate while estimating bytes"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d73a1dc5",
   "metadata": {},
   "source": [
    "##### post_questions table"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 41,
   "id": "b953c4e7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
